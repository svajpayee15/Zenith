<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zenith Bot | Revoke</title>
    <style>
       body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: #121212;
    margin: 0;
    color: #e4e4e4;
}

.card {
    background: #1e1e1e;
    padding: 2.5rem;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.6);
    text-align: center;
    max-width: 400px;
    width: 100%;
}

h2 {
    margin-bottom: 10px;
    color: #ffffff;
}

p {
    color: #b0b0b0;
    margin-bottom: 20px;
}

button {
    background: #ff4d5a;
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    transition: background 0.3s, transform 0.1s;
    width: 100%;
}

button:hover {
    background: #d93644;
    transform: translateY(-1px);
}

button:disabled {
    background: #444;
    color: #888;
    cursor: not-allowed;
}

.hidden {
    display: none;
}

.status-text {
    margin-top: 15px;
    font-size: 14px;
    font-weight: bold;
    color: #ff6b6b;
}

.wallet-key {
    font-family: monospace;
    background: #2a2a2a;
    padding: 6px;
    border-radius: 6px;
    font-size: 12px;
    color: #ddd;
}
    </style>
</head>
<body>

    <div class="card">
        <h2>Revoke Trading Bot</h2>
        <p>User ID: <strong id="displayUserId">...</strong></p>

        <div id="step1">
            <p>Connect your Solana wallet to revoke permissions.</p>
            <button id="connectBtn" style="background: #007bff;">Connect Phantom</button>
        </div>

        <div id="step2" class="hidden">
            <p style="color: green;">✅ Wallet Connected</p>
            <p id="walletAddress" class="wallet-key"></p>
            <button id="signBtn">Sign & Revoke</button>
            <div id="statusMessage" class="status-text hidden"></div>
        </div>

        <div id="success" class="hidden">
            <h3 style="color: green;">🚫 Revocation Successful</h3>
            <p>The bot permissions have been removed.</p>
            <p>You can close this window.</p>
        </div>
    </div>

    <script>
        const pathParts = window.location.search;
        const urlParams = new URLSearchParams(pathParts);
        const userId = urlParams.get("userId")    

        const AGENT_WALLET_ADDRESS = "AF7dARxRpj1JgRJZdJMgPonKcJTkbZhL6GEA4jkZm5qo"; 

        document.getElementById('displayUserId').innerText = userId;
        let userWalletKey = null;

        function sortRecursive(item) {
            if (typeof item !== 'object' || item === null) return item;
            if (Array.isArray(item)) return item.map(sortRecursive);
            return Object.keys(item).sort().reduce((acc, key) => {
                acc[key] = sortRecursive(item[key]);
                return acc;
            }, {});
        }

        function updateStatus(msg) {
            const el = document.getElementById('statusMessage');
            el.innerText = msg;
            el.classList.remove('hidden');
        }

        async function connectWallet() {
            const provider = window.solana;
            if (!provider || !provider.isPhantom) {
                alert("Phantom Wallet not found! Please install it.");
                return;
            }

            try {
                const resp = await provider.connect();
                userWalletKey = resp.publicKey.toString();

                document.getElementById('step1').classList.add('hidden');
                document.getElementById('step2').classList.remove('hidden');
                document.getElementById('walletAddress').innerText = userWalletKey.slice(0, 6) + '...' + userWalletKey.slice(-6);
            } catch (err) {
                console.error(err);
                alert("Connection denied!");
            }
        }

        async function processRevocation() {
            const signBtn = document.getElementById('signBtn');
            signBtn.disabled = true;

            try {
                // 1. Prepare Payload 1 (Builder Code)
                updateStatus("1/4 Signing Builder Revocation...");
                
                const payload1 = {
                    timestamp: Date.now(),
                    expiry_window: 5000,
                    type: "revoke_builder_code",
                    data: { builder_code: "prathamdev69" }
                };

                const sortedPayload1 = sortRecursive(payload1);
                const msgBytes1 = new TextEncoder().encode(JSON.stringify(sortedPayload1));
                const { signature: sig1 } = await window.solana.signMessage(msgBytes1, 'utf8');

                // 2. Prepare Payload 2 (Agent Wallet)
                updateStatus("2/4 Signing Agent Revocation...");

                const payload2 = {
                    timestamp: Date.now(),
                    expiry_window: 5000,
                    type: "revoke_agent_wallet",
                    data: { agent_wallet: AGENT_WALLET_ADDRESS }
                };

                const sortedPayload2 = sortRecursive(payload2);
                const msgBytes2 = new TextEncoder().encode(JSON.stringify(sortedPayload2));
                const { signature: sig2 } = await window.solana.signMessage(msgBytes2, 'utf8');

                // 3. Send Request 1
                updateStatus("3/4 Sending Builder Revocation...");
                
                const res1 = await fetch('/auth/verify/revoke', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userId: userId,
                        walletAddress: userWalletKey,
                        signature: Array.from(sig1),
                        payload: sortedPayload1
                    })
                });

                const response1 = await res1.json()
                console.log(response1.code)
                if(!res1.ok && !response1.code == 409) throw new Error("Try Again")

                // 4. Send Request 2
                updateStatus("4/4 Sending Agent Revocation...");

                const apiPayloadAgent = {
                    account: userWalletKey,
                    signature: Array.from(sig2),
                    timestamp: payload2.timestamp,
                    expiry_window: payload2.expiry_window,
                    agent_wallet: AGENT_WALLET_ADDRESS
                };
                const sortedAPIPayloadAgent = sortRecursive(apiPayloadAgent);

                const res2 = await fetch("/auth/agent/revoke", {
                    method: "POST",
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userId: userId,
                        payload: sortedAPIPayloadAgent
                    })
                });

                if(!res2.ok) throw new Error("Try Again")
                document.getElementById('step2').classList.add('hidden');
                document.getElementById('success').classList.remove('hidden');

            } catch (err) {
                console.error("Revocation Failed:", err);
                updateStatus("❌ Error: " + (err.message || "Unknown error"));
                signBtn.disabled = false;
                alert("Revocation failed: " + err.message);
            }
        }

        // --- Attach Event Listeners (CSP-safe) ---
document.getElementById("connectBtn")
  .addEventListener("click", connectWallet);

document.getElementById("signBtn")
  .addEventListener("click", processRevocation);

    </script>
</body>
</html>
